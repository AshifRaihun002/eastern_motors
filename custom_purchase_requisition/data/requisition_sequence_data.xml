<odoo>
    <data noupdate="1">
        <!-- Define the sequence for procurement.plan -->
        <record id="seq_purchase_requisition" model="ir.sequence">
            <field name="name">Purchase Requisition</field>
            <field name="code">custom.purchase.requisition</field>
            <field name="prefix">PR/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
            <!--            <field name="prefix_date">year</field>-->
        </record>

    </data>
</odoo>