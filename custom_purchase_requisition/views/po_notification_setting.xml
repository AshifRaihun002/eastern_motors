<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_po_notification" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.po.notification</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="PO Notification" name="po_notification_app">
                        <block title="PO Delivery Reminder">
                            <setting string="Notification Send Interval Days">
                                <field name="po_notification_send_interval"/>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>