<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the Purchase Order form view -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.brac</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header/button[@name='button_confirm']" position="after">
                <!-- Approve button -->
                <button name="action_send_po_group_email" type="object" string="Send Notification" class="oe_highlight"
                        invisible="state in ('draft','cancel','sent')"/>
                <button name="action_open_order_status_wizard"
                        string="Update Order Status"
                        type="object"
                        class="btn-primary"/>
            </xpath>
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="indent_reference"/>
                <field name="order_status"/>
                <field name="last_po_notification_date" readonly="1" force_save="1" invisible="1"/>
                <field name="vendor_delivery_status"/>
                <field name="ven_delivery_state_date" widget="date"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Order Status History">
                    <field name="order_status_record_ids" readonly="1" force_save="1">
                        <list create="0" delete="0" edit="0">
                            <field name="action_date"/>
                            <field name="field_name" column_invisible="1"/>
                            <field name="from_state"/>
                            <field name="to_state"/>
                            <field name="action_by"/>
                            <field name="remarks"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/field[@name='date_planned']" position="after">

                <field force_save="1" name="requisition_id" optional="hide" readonly="1"/>
                <field name="requisition_line_id" optional="hide" readonly="1" force_save="1"/>
                <field name="size" readonly="1" force_save="1"/>
                <field name="pr" readonly="1" force_save="1"/>
                <field name="pattern" force_save="1" readonly="1"/>
                <field name="hs_code" readonly="1" force_save="1"/>
                <field name="weight" readonly="1" force_save="1"/>

            </xpath>
        </field>
    </record>
</odoo>