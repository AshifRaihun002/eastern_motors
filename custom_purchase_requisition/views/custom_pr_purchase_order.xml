<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the Purchase Order form view -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.brac</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='date_planned']" position="after">

                <field force_save="1" name="requisition_id" optional="hide" readonly="1"/>
                <field name="requisition_line_id" optional="hide" readonly="1" force_save="1"/>
                <field name="size" readonly="1" force_save="1"/>
                <field name="pr" readonly="1" force_save="1"/>
                <field name="pattern" force_save="1" readonly="1"/>
                <field name="hs_code" readonly="1" force_save="1"/>
                
            </xpath>
        </field>
    </record>
</odoo>