        <!-- Action -->

        <record id="action_purchase_requisition" model="ir.actions.act_window">
            <field name="name">Purchase Requisitions</field>
            <field name="res_model">custom.purchase.requisition</field>
            <field name="view_mode">list,form,graph,pivot</field>
            <field name="search_view_id" ref="view_requisition_process_search"/>
        </record>
        <record id="action_req_approval" model="ir.actions.act_window">
            <field name="name">REQ Approval</field>
            <field name="res_model">approval.config</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_approval_type': 'requisition','default_has_employee_id': 1}</field>
            <field name="domain">[('approval_type', '=', 'requisition')]</field>
        </record>
        <!-- Menu Item -->
        <menuitem id="menu_purchase_requisition_root" name="REQ" sequence="10"
                  web_icon="custom_purchase_requisition,static/description/purchase.png"/>
        <menuitem action="action_purchase_requisition" id="menu_purchase_requisition" name="Purchase Requisitions"
                  parent="purchase.menu_purchase_root" sequence="2"/>

        <menuitem id="purchase_requisitions_all" name="Requisition" parent="menu_purchase_requisition"
                  action="action_purchase_requisition" sequence="9"/>


        <record id="approve_requisition_server_action" model="ir.actions.server">
            <field name="name">Approve Requisition</field>
            <field name="model_id" ref="custom_purchase_requisition.model_custom_purchase_requisition"/>
            <field name="binding_model_id" ref="custom_purchase_requisition.model_custom_purchase_requisition"/>
            <field name="state">code</field>
            <field name="code">
                if records:
                records.filtered(lambda r: r.state == 'approval_pending').approve_requisition()
            </field>
        </record>
