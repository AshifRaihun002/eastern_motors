    <record id="action_all_inter_company_transfer" model="ir.actions.act_window">
        <field name="name">All Transfers</field>
        <field name="res_model">inter.company.transfer.line</field>
        <field name="view_mode">list,graph,pivot</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False, 'copy': False}</field>
    </record>

    <record id="action_inter_company_transfer" model="ir.actions.act_window">
        <field name="name">Inter Company Transfers</field>
        <field name="res_model">inter.company.transfer</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="help" type="html">
