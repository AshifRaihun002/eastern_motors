<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="so_send_back_note_form" model="ir.ui.view">
            <field name="name">so.send.back.note.form</field>
            <field name="model">sent.back.wizard.so</field>
            <field name="arch" type="xml">
                <form string="Send Back Note">
                    <sheet>
                        <group>
                            <field name="note" required="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button class="btn-success"
                                name="send_back_so"
                                string="Send Back"
                                type="object"/>
                        <button class="btn-danger"
                                special="cancel"
                                string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_so_send_back_note" model="ir.actions.act_window">
            <field name="name">Send Back Note</field>
            <field name="res_model">sent.back.wizard.so</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="so_send_back_note_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>