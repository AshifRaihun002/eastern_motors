<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="inherit_sale_order_form" model="ir.ui.view">
        <field name="name">sale.order.custom.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sent,sale,approval_pending,cancel</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header" position="inside">

                <button name="action_submit_for_approval"
                        string="Submit for Approval"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('draft', 'sent')"/>

                <button name="approve_sale_order"
                        string="Approve"
                        type="object"
                        class="btn-success"
                        invisible="state != 'approval_pending' or is_user_approver == False"/>

                <button name="send_back_note"
                        string="Send Back"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'approval_pending' or is_user_approver == False"/>

                <field name="stage_id" widget="statusbar"/>


            </xpath>
            <xpath expr="//page[@name='other_information']//group" position="inside">
                <group string="Approval Information">
                    <field name="approval_config_id" readonly="1" force_save="1"/>
                    <field name="stage_id" readonly="1" force_save="1"/>
                    <field name="authorised_by_id" readonly="1"/>
                    <field name="is_user_approver" invisible="1"/>
                </group>
            </xpath>
            <!-- Add customer info after partner_id -->
            <xpath expr="//notebook" position="inside">
                <page string="Approval History">
                    <field name="approval_history_ids" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="date"/>
                            <field name="stage_id"/>
                            <field name="to_stage_id"/>
                            <field name="user_id"/>
                            <field name="action_type"/>
                            <field name="note"/>
                        </list>
                    </field>
                </page>
                <page name="credit_security_tab" string="Credit &amp; Security">
                    <field name="is_credit_limit_exceeded" invisible="1"/>
                    <group name="customer_credit_info" string="Customer Credit Information" col="2">
                        <group>
                            <field name="customer_type"/>
                            <field name="payment_type"/>
                            <field name="credit_limit" widget="monetary" readonly="1"/>
                            <field name="credit_used_amount" widget="monetary" readonly="1"
                                   invisible="payment_type != 'credit'"/>
                            <field name="remaining_credit" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="projected_remaining_credit" widget="monetary" readonly="1"/>
                            <field name="credit_overdue_amount" widget="monetary" readonly="1"
                                   invisible="credit_overdue_amount == 0"/>
                            <field name="is_security_money_apply" readonly="1"/>
                            <field name="security_money" widget="monetary"
                                   invisible="not is_security_money_apply" readonly="1"/>
                        </group>
                    </group>

                    <!-- Credit Usage Details -->
                    <group name="credit_usage_details" string="Credit Usage Details"
                           invisible="credit_limit == 0 or payment_type != 'credit'">
                        <group>
                            <field name="credit_limit" widget="monetary" readonly="1"/>
                            <field name="credit_used_amount" widget="monetary" readonly="1"/>
                            <field name="remaining_credit" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="projected_remaining_credit" widget="monetary" readonly="1"/>
                            <field name="credit_overdue_amount" widget="monetary" readonly="1"
                                   invisible="credit_overdue_amount == 0"/>
                        </group>
                        <field name="credit_used_sale_order_ids" readonly="1"
                               context="{'tree_view_ref': 'sale.view_quotation_tree_with_onboarding'}">
                            <list string="Credit Used Sales" create="0" delete="0" edit="0">
                                <field name="name"/>
                                <field name="date_order"/>
                                <field name="partner_id"/>
                                <field name="amount_total"/>
                                <field name="state"/>
                                <field name="payment_type"/>
                            </list>
                        </field>
                    </group>

                    <!-- Note Section -->
                    <div class="alert alert-info mt-3" role="alert">
                        <i class="fa fa-info-circle"></i>
                        <strong>Note:</strong>
                        <ul style="margin-bottom: 0; margin-top: 5px;">
                            <li>Remaining credit shows the customer's currently available balance</li>
                            <li>Only payment type Credit consumes the customer's credit limit</li>
                            <li>Remaining after this order shows the balance after this quotation amount</li>
                            <li>Credit warning and blocking apply only for credit orders</li>
                        </ul>
                    </div>
                </page>
            </xpath>

            <!-- Add warning for credit limit -->
            <xpath expr="//field[@name='order_line']" position="before">
                <div class="alert alert-warning"
                     role="alert"
                     invisible="payment_type != 'credit' or not is_credit_limit_exceeded or credit_limit == 0.0">
                    <i class="fa fa-warning"/>
                    <strong>Warning!</strong>
                    Customer credit limit is exceeded by
                    <strong>
                        <field name="credit_overdue_amount" nolabel="1" class="oe_inline"/>
                    </strong>
                    .
                </div>
                <div class="alert alert-info"
                     role="alert"
                     invisible="payment_type != 'credit' or remaining_credit >= (credit_limit * 0.2) or credit_limit == 0 or remaining_credit &lt;= 0">
                    <i class="fa fa-info-circle"/>
                    <strong>Info:</strong>
                    Customer remaining credit is only
                    <strong>
                        <field name="remaining_credit" nolabel="1" class="oe_inline"/>
                    </strong>
                    (less than 20%).
                </div>
            </xpath>
        </field>
    </record>
</odoo>
