<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree/List View -->
    <record id="view_approval_history_list" model="ir.ui.view">
        <field name="name">Approval History List</field>
        <field name="model">approval.history</field>
        <field name="arch" type="xml">
            <list string="Approval History">
                <field name="date"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="action_type"/>
                <field name="stage_id"/>
                <field name="to_stage_id"/>
                <field name="res_model"/>
                <field name="res_name"/>
                <field name="note"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="view_approval_history_form" model="ir.ui.view">
        <field name="name">Approval History Form</field>
        <field name="model">approval.history</field>
        <field name="arch" type="xml">
            <form string="Approval History">
                <sheet>
                    <group>
                        <field name="date" readonly="1"/>
                        <field name="company_id" readonly="1" force_save="1"/>
                        <field name="user_id" readonly="1"/>
                        <field name="action_type" readonly="1"/>
                        <field name="stage_id" readonly="1" force_save="1"/>
                        <field name="to_stage_id" readonly="1" force_save="1"/>
                    </group>
                    <group>
                        <field name="res_model" readonly="1"/>
                        <field name="res_id" readonly="1"/>
                        <field name="res_name" readonly="1"/>
                    </group>
                    <group>
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="action_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">approval.history</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- Menu -->
    <!--    <menuitem id="menu_approval_history" name="Approval History" parent="root_approval_menu" action="action_approval_history" sequence="2"/>-->
</odoo>
