<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_config_form" model="ir.ui.view">
        <field name="name">approval.config.form</field>
        <field name="model">approval.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="approval_type"/>
                            <field name="company_id" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="approval_line_tab" string="Approval Lines">
                            <field mode="list" name="approval_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="user_ids"
                                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                           widget="many2many_tags"/>
                                    <field name="approve_in_bulk"/>
                                    <field name="company_id" readonly="True" force_save="1" options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                                    <field name="type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_approval_config_tree" model="ir.ui.view">
        <field name="name">approval.config.list</field>
        <field name="model">approval.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="approval_type"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>
    <record id="action_approval_config" model="ir.actions.act_window">
        <field name="name">Approval Configuration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">approval.config</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="root_approval_menu" name="Approval" sequence="40" web_icon="dynamic_approval_process,static/description/icon.png"/>
    <menuitem action="action_approval_config" groups="base.group_erp_manager" id="approval_menu"
              name="Approval Configuration" parent="dynamic_approval_process.root_approval_menu" sequence="1"/>
</odoo>
