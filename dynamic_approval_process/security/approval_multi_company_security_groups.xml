<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="approval_config_multi_company_rule" model="ir.rule">
            <field name="name">Approval Config: multi-company</field>
            <field name="model_id" ref="dynamic_approval_process.model_approval_config"/>
<!--            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>-->
            <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="approval_line_multi_company_rule" model="ir.rule">
            <field name="name">Approval Line: multi-company</field>
            <field name="model_id" ref="dynamic_approval_process.model_approval_line"/> <!-- replace module_name -->
            <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="send_back_wizard_multi_company_rule" model="ir.rule">
            <field name="name">SB: Multi-company</field>
            <field name="model_id" ref="dynamic_approval_process.model_send_back_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>