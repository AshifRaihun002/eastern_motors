<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Category-->
        <record id="module_category_target_management" model="ir.module.category">
            <field name="name">Target Management</field>
            <field name="description">Access to target management</field>
            <field name="sequence">20</field>
        </record>

        <!--Privilege-->
        <record id="privilege_crud_access" model="res.groups.privilege">
            <field name="name">Access Control</field>
            <field name="category_id" ref="module_category_target_management"/>
            <field name="sequence">0</field>
        </record>

        <!--Group-->
        <record id="group_target_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="privilege_id" ref="privilege_crud_access"/>
            <field name="comment">Can View Target Informations</field>
        </record>

        <record id="group_target_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_crud_access"/>
            <field name="implied_ids" eval="[(4, ref('group_target_viewer'))]"/>
            <field name="comment">Have CRUD access to target management</field>
        </record>

        <record id="group_target_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="privilege_id" ref="privilege_crud_access"/>
            <field name="implied_ids" eval="[(4, ref('group_target_user'))]"/>
            <field name="comment">Have all access related to target management</field>
        </record>

    </data>
</odoo>