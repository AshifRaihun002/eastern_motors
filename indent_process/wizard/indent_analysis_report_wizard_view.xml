<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_indent_analysis_wizard_form" model="ir.ui.view">
            <field name="name">indent.analysis.wizard.form</field>
            <field name="model">indent.analysis.wizard</field>
            <field name="arch" type="xml">
                <form string="Indent Analysis Report">
                    <group>
                        <group>
                            <field name="from_date"/>
                            <field name="to_date"/>
                        </group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="unit_id" options="{'no_create': True}"/>
                            <field name="report_type"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_pdf" string="Print PDF" type="object" class="btn-primary"/>
                        <button name="action_print_excel" string="Print Excel" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_indent_analysis_wizard" model="ir.actions.act_window">
            <field name="name">Indent Analysis</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">indent.analysis.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_indent_analysis_report" name="Indent Analysis" parent="indent_process.menu_indent_root" action="action_indent_analysis_wizard" sequence="105"/>
    </data>
</odoo>
