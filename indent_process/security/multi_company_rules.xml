            <field name="model_id" ref="indent_process.model_indent_process"/>
            <field name="domain_force">[('company_id', 'in', company_ids),('factory_plant', 'in', allowed_plants)]</field>
        </record>
        <record id="indent_line_multi_company_rule" model="ir.rule">
            <field name="name">IL: Multi-company</field>
            <field name="model_id" ref="indent_process.model_indent_line"/>
