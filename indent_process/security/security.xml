<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <!-- Categories -->

        <record model="res.groups.privilege" id="module_category_indent_process">
            <field name="name">Indent Process</field>
            <field name="description">Indent Process Security Groups</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groups -->
        <record id="group_indent_requester" model="res.groups">
            <field name="name">Indent Requester</field>
             <field name="privilege_id" ref="indent_process.module_category_indent_process"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_indent_issuer" model="res.groups">
            <field name="name">Indent Issuer</field>
             <field name="privilege_id" ref="indent_process.module_category_indent_process"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_indent_admin" model="res.groups">
            <field name="name">Indent Admin</field>
             <field name="privilege_id" ref="indent_process.module_category_indent_process"/>
            <field name="implied_ids" eval="[(4, ref('indent_process.group_indent_issuer')), (4, ref('indent_process.group_indent_requester'))]"/>
        </record>
    </data>

    <data noupdate="0">
        <!-- Record Rules -->
        <record id="rule_indent_process_requester" model="ir.rule">
            <field name="name">Indent Process: Requester</field>
            <field name="model_id" ref="indent_process.model_indent_process"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('indent_process.group_indent_requester'))]"/>
        </record>

        <record id="rule_indent_process_issuer" model="ir.rule">
            <field name="name">Indent Process: Issuer</field>
            <field name="model_id" ref="indent_process.model_indent_process"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('indent_process.group_indent_issuer'))]"/>
        </record>

        <record id="rule_indent_process_admin" model="ir.rule">
            <field name="name">Indent Process: Admin</field>
            <field name="model_id" ref="indent_process.model_indent_process"/>
            <field name="domain_force">[('company_id', 'in', company_ids),(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('indent_process.group_indent_admin'))]"/>
        </record>
    </data>
</odoo>
