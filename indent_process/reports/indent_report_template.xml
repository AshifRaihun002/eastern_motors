<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="indent_report_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 10px; font-family: Arial, sans-serif;">
                        <div class="text-center" style="font-weight: bold; font-size: 16px; margin-bottom: 5px; text-decoration: underline;">
                            STORE INDENT AND ISSUE BETWEEN
                        </div>
                        <div class="text-center" style="font-weight: bold; font-size: 14px; margin-bottom: 20px;">
                            From <span t-esc="from_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                            To <span t-esc="to_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                    </div>

                    <table class="table table-sm table-bordered" style="width: 100%; border-collapse: collapse;">
                        <thead style="background-color: #f2f2f2;">
                            <tr>
                                <th>S.no</th>
                                <th>Indent No</th>
                                <th>Indent Date</th>
                                <th>Item Name[Code]</th>
                                <th>Internal Name</th>
                                <th>Uom</th>
                                <th>Item status</th>
                                <th>Indent qty</th>
                                <th>Issue Date</th>
                                <th>To Department</th>
                                <th>Issue Qty</th>
                                <th>Return Qty</th>
                                <th>Lot ID</th>
                                <th>Net Issue Qty</th>
                                <th>Unit Rate</th>
                                <th>Issue Amt</th>
                                <th>User Name</th>
                                <th>ShipmentNo</th>
                                <th>ShipmentDate</th>
                                <th>SupplierName</th>
                                <th>MFGDate</th>
                                <th>ExpireDate</th>
                                <th>Comment</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_issue_amt" t-value="0.0"/>
                            <t t-set="serial" t-value="1"/>
                            <t t-foreach="lines" t-as="line">
                                <tr>
                                    <td>
                                        <t t-esc="serial"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['indent_no']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['indent_date']" t-options='{"widget": "date"}'/>
                                    </td>
                                    <td>
                                        <t t-esc="line['product_name']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['internal_name']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['uom']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['status']"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['indent_qty'])"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['issue_date']" t-options='{"widget": "date"}'/>
                                    </td>
                                    <td>
                                        <t t-esc="line['to_dept']"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['issue_qty'])"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['return_qty'])"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['lot_id']"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['net_issue_qty'])"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['unit_rate'])"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{0:,.2f}'.format(line['issue_amt'])"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['user_name']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['shipment_no']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['shipment_date']" t-options='{"widget": "date"}'/>
                                    </td>
                                    <td>
                                        <t t-esc="line['supplier_name']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['mfg_date']" t-options='{"widget": "date"}'/>
                                    </td>
                                    <td>
                                        <t t-esc="line['exp_date']" t-options='{"widget": "date"}'/>
                                    </td>
                                    <td>
                                        <t t-esc="line['comment']"/>
                                    </td>
                                    <td>
                                        <t t-esc="line['remarks']"/>
                                    </td>
                                </tr>
                                <t t-set="total_issue_amt" t-value="total_issue_amt + line['issue_amt']"/>
                                <t t-set="serial" t-value="serial + 1"/>
                            </t>
                            <tr>
                                <td colspan="15" class="text-right" style="font-weight: bold;">TOTAL</td>
                                <td class="text-right" style="font-weight: bold;">
                                    <t t-esc="'{0:,.2f}'.format(total_issue_amt)"/>
                                </td>
                                <td colspan="8"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</data>
</odoo>
