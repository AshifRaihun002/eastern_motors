<odoo>
    <data noupdate="1">
        <!-- Define the sequence for indent.process -->
        <record id="indent_process_seq" model="ir.sequence">
            <field name="name">Indent Process</field>
            <field name="code">indent.process</field>
            <field name="prefix">IP/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>