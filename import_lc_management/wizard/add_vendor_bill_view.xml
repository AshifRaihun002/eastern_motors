<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="view_lc_vendor_bill_wizard_form" model="ir.ui.view">
        <field name="name">lc.vendor.bill.wizard.form</field>
        <field name="model">lc.vendor.bill.wizard</field>
        <field name="arch" type="xml">
            <form string="Create CNF Vendor Bill" create="false" edit="false">
                <group>
                    <field name="lc_id" readonly="1"/>
                    <field name="vendor_id"/>
                    <field name="currency_id"/>
                </group>

                <field name="bill_line_ids">
                    <list editable="bottom">
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="amount"/>
                        <field name="account_id"/>
                    </list>
                </field>

                <footer>
                    <button string="Create Bill" type="object" name="action_create_vendor_bill" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_lc_vendor_bill_wizard" model="ir.actions.act_window">
        <field name="name">Create Vendor Bill</field>
        <field name="res_model">lc.vendor.bill.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_lc_vendor_bill_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

</odoo>
