<odoo>
    <!-- Form view for the Custom Duty Wizard -->
    <record id="view_lc_custom_duty_wizard_form" model="ir.ui.view">
        <field name="name">lc.custom.duty.wizard.form</field>
        <field name="model">lc.custom.duty.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Custom Duty Journal Entry">
                <group>
                    <field name="lc_id"/>
                    <field name="journal_id"/>
                </group>
                <field name="wizard_line_ids">
                    <list editable="bottom">
                        <field name="product_id"/>
                        <field name="landed_cost_type"/>
                        <field name="account_id"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                        <field name="original_cost_line_id" column_invisible="1"/>
                    </list>
                </field>
                <footer>
                    <button string="Create Journal Entry" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_lc_custom_duty_wizard" model="ir.actions.act_window">
        <field name="name">Custom Duty Journal</field>
        <field name="res_model">lc.custom.duty.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_lc_custom_duty_wizard_form"/>
    </record>
</odoo>