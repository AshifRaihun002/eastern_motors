<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="view_shipment_custom_duty_wizard_form" model="ir.ui.view">
            <field name="name">shipment.custom.duty.wizard.form</field>
            <field name="model">shipment.custom.duty.wizard</field>
            <field name="arch" type="xml">
                <form string="Create Custom Duty Journal Entry">
                    <sheet>
                        <group>
                            <group>
                                <field name="shipment_id" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="journal_id" required="1"/>
                            </group>
                        </group>

                        <field name="wizard_line_ids">
                            <list editable="bottom">
                                <field name="product_id" readonly="1" force_save="1"/>
                                <field name="landed_cost_type" readonly="1" force_save="1"/>
                                <field name="account_id" readonly="1" force_save="1"/>
                                <field name="amount" readonly="1" force_save="1"/>
                                <field name="currency_id" readonly="1" force_save="1"/>
                            </list>
                        </field>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Create Journal Entry" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="action_shipment_custom_duty_wizard" model="ir.actions.act_window">
            <field name="name">Create Custom Duty Journal Entry</field>
            <field name="res_model">shipment.custom.duty.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="view_shipment_custom_duty_wizard_form"/>
        </record>
    </data>
</odoo>