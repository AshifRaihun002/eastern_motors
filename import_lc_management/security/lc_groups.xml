<?xml version="1.0" ?>
<odoo>
  <data noupdate="0">

    <record id="module_category_lc" model="res.groups.privilege">
      <field name="name">L/C</field>
      <field name="description">Helps you handle your L/C requests.</field>
      <field name="sequence">1</field>
    </record>

    <record id="group_lc_own" model="res.groups">
      <field name="name">User: Own Documents Only</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
      <field name="comment">The user will have access to his own data in the L/C application.</field>
    </record>

    <record id="group_lc_user" model="res.groups">
      <field name="name">User: All Documents</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('import_lc_management.group_lc_own'))]"/>
      <field name="comment">The user will have access to all records of everyone in the L/C application.</field>
    </record>

    <record id="group_lc_manager" model="res.groups">
      <field name="name">Administrator</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('import_lc_management.group_lc_user'))]"/>
<!--      <field name="group_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>-->
      <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
      <field name="comment">The user will have an access to the L/C configuration as well as statistic reports.</field>
    </record>

    <record id="group_lc_ass_manager" model="res.groups">
      <field name="name">Assistant Manager</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_lc_senior_manager" model="res.groups">
      <field name="name">Senior Manager</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_lc_head_scm" model="res.groups">
      <field name="name">Head of SCM</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_lc_head_dept" model="res.groups">
      <field name="name">Head of Department(view only)</field>
      <field name="privilege_id" ref="module_category_lc"/>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_pasha_lc_manager" model="res.groups">
      <field name="name">LC Manager</field>
      <field name="privilege_id" ref="module_category_lc"/>
<!--      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>-->
    </record>

  </data>
</odoo>
