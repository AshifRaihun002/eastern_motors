    <!-- Window Action -->


    <record id="landed_cost_type_action_window" model="ir.actions.act_window">
        <field name="name">Landed Cost Type</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_landed_cost_ok': True, 'default_detailed_type': 'service'}</field>
        <field name="domain">[('landed_cost_ok', '=', True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Landed Cost Type found. Let's create one!
            </p>
        </field>
    </record>


    <record id="landed_cost_template_action_window" model="ir.actions.act_window">
        <field name="name">Landed Cost Template</field>
        <field name="res_model">landed.cost.template</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Landed Cost Template found. Let's create one!
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="landed_cost" name="Landed Cost" parent="import_lc_management.menu_root" groups="stock.group_stock_user"
              sequence="20"/>
    <menuitem id="landed_cost_menu" name="Landed Cost" parent="import_lc_management.landed_cost"
              groups="stock.group_stock_user"
              action="stock_landed_costs.action_stock_landed_cost" sequence="10"/>
    <menuitem id="landed_cost_type_menu" name="Landed Cost Type" parent="import_lc_management.landed_cost"
              groups="stock.group_stock_user" action="landed_cost_type_action_window" sequence="15"/>
    <menuitem id="landed_cost_template_menu" name="Landed Cost Template" parent="import_lc_management.landed_cost"
              groups="stock.group_stock_user" action="landed_cost_template_action_window" sequence="20"/>


