<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="landed_cost_template_view_tree" model="ir.ui.view">
        <field name="name">Landed Cost Template View Tree</field>
        <field name="model">landed.cost.template</field>
        <field name="arch" type="xml">
            <list string="Landed Cost Template" default_order="id desc">
                <field name="company_id" invisible="1"/>
                <field name="name" string="Reference"/>
                <field name="product_id"/>
                <field name="user_id" optional="show" widget='many2one_avatar_user'/>
                <field name="template_date" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" readonly="1" optional="hide"/>
                <field name="currency_id" optional="show" readonly="1" force_save="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="landed_cost_template_view_form" model="ir.ui.view">
        <field name="name">Landed Cost Template View Form</field>
        <field name="model">landed.cost.template</field>
        <field name="arch" type="xml">
            <form string="Landed Cost Template">
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <field name="company_id"/>
                    <group>
                        <group name="lc_info">
                            <field name="product_id"/>
                            <field name="template_date"/>
                        </group>
                        <group name="additional_details">
                            <field name="user_id" domain="[('share', '=', False)]" options="{'no_create': True}"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"
                                   force_save="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Additional Cost Lines" name="cost_lines">
                            <field name="cost_lines">
                                <list string="Cost Lines" editable="bottom" create="True">
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="template_id" column_invisible="1"/>
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="account_id"/>
                                    <field name="landed_cost_type"/>
                                    <field name="split_method"/>
                                    <field name="price_unit"/>
                                    <field name="company_id" groups="base.group_multi_company" readonly="1" force_save="1" optional="hide"/>
                                    <field name="company_currency_id" optional="show" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Internal Notes">
                            <field name="internal_notes" placeholder="Add Internal Notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_follower="True"/>
            </form>
        </field>
    </record>

