<odoo>
    <record id="view_users_form" model="ir.ui.view">
        <field name="name">res.users.form.inherit.multi.warehouses</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Add fields after access_rights page -->
            <xpath expr="//page[@name='access_rights']/group" position="after">
                <group name="multi_warehouses" string="Multi Warehouses">
                    <field name="warehouse_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="property_warehouse_id" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>