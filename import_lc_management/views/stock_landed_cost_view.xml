<?xml version="1.0"?>
<odoo>

    <record id="actual_landed_cost_form_view" model="ir.ui.view">
        <field name="name">actual.landed.cost.form.view</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">

            <button name="button_cancel" position="before">
                <field name="show_add_cost_line" invisible="1"/>
                <button name="populate_cost_lines" string="Populate Cost Lines" class="oe_highlight"
                        invisible="show_add_cost_line == 0" type="object"/>
            </button>

            <button name="button_validate" position="after">
                <button name="post_actual_cost" string="Post Actual Cost" state="done" class="oe_highlight"
                        invisible="1"
                        type="object"/>
            </button>

            <!--            <xpath expr="//div[@name='button_box']/button[@name='action_view_stock_valuation_layers']"-->
            <!--                   position="attributes">-->
            <!--                <attribute name="invisible">state not in ('done','actual') or 'stock_valuation_layer_ids' == []-->
            <!--                </attribute>-->
            <!--            </xpath>-->

            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button string="Journal Items"
                            type="object"
                            name="action_view_journal_items"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"/>
                </div>
            </xpath>

            <field name="account_move_id" position="after">
                <field name="actual_account_move_id" invisible="state != 'actual'"/>
                <field name="actual_cost_val_date" invisible="state != 'actual'"/>
                <field name="lc_id" readonly="1" force_save="1" invisible="1"/>
            </field>

            <xpath expr="//page[@name='additional_costs']/field[@name='cost_lines']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>

            <xpath expr="//list/field[@name='price_unit']" position="after">
                <field name="state" column_invisible="1"/>
                <field name="is_only_actual" column_invisible="1"/>
                <field name="price_unit_actual"
                       required="state == 'done'" readonly="state in ('draft','actual')"/>
            </xpath>

            <xpath expr="//list/field[@name='product_id']" position="attributes">
                <attribute name="readonly">state != 'draft' or 'is_only_actual' == 'False'

                </attribute>
            </xpath>
            <xpath expr="//list/field[@name='name']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
            <xpath expr="//list/field[@name='account_id']" position="attributes">
                <attribute name="readonly">state != 'draft' or 'is_only_actual' =='False'
                </attribute>
            </xpath>
            <xpath expr="//list/field[@name='split_method']" position="attributes">
                <attribute name="readonly">state != 'draft' or 'is_only_actual' == 'False'
                </attribute>
            </xpath>
            <xpath expr="//list/field[@name='price_unit']" position="attributes">
                <attribute name="readonly">state != 'draft' or 'is_only_actual' == 'False'
                </attribute>
            </xpath>

        </field>
    </record>


</odoo>