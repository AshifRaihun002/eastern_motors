        <!-- Action for LC Shipment -->
        <record id="action_lc_shipment_view" model="ir.actions.act_window">
            <field name="name">LC Shipments</field>
            <field name="res_model">lc.shipment</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first LC Shipment
                </p>
            </field>
        </record>

        <record id="view_stock_picking_form_inherit_lc_shipment" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.lc.shipment</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <!-- Add lc_shipment_id field after the origin field -->
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="lc_shipment_id"
                           readonly="1"
                           force_save="1"
                           placeholder="LC Shipment Reference"/>
                </xpath>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_lc_shipment_root" name="LC Shipments"
                  parent="import_lc_management.menu_root" sequence="10"/>

        <menuitem id="menu_lc_shipment"
                  name="All Shipments"
                  parent="menu_lc_shipment_root"
                  action="action_lc_shipment_view"
                  sequence="10"/>

    </data>
</odoo>