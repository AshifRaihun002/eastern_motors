<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View for LC Shipment -->
        <record id="view_lc_shipment_form" model="ir.ui.view">
            <field name="name">lc.shipment.form</field>
            <field name="model">lc.shipment</field>
            <field name="arch" type="xml">
                <form string="LC Shipment">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"
                                invisible="state in ('confirmed','received','cancelled')"/>
                        <button name="action_receive" string="Mark as Received" type="object" class="btn-primary" invisible="1"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"
                                invisible="state in ('confirmed','received','cancelled')"/>
                        <button name="action_draft" string="Reset to Draft" type="object" class="btn-secondary"/>
                        <button name="get_shipment_cost_line_values" type="object" class="btn-primary"
                                string="Populate Cost Line" invisible="state in('draft','cancelled')"/>
                        <button name="action_create_shipment_payment_entry"
                                string="Create Shipment Payment"
                                class="btn-primary"
                                type="object"
                                invisible="state in('draft','cancelled') or payment_type != 'sight'"/>
                        <button
                                name="open_shipment_custom_duty_wizard"
                                string="Create Custom Duty Entry"
                                type="object"
                                class="btn-primary"
                                invisible="state in('draft','cancelled')"
                        />
                        <button
                                name="action_open_vendor_bill_wizard"
                                string="Bills For Add Charge"
                                type="object"
                                class="btn-primary"
                                invisible="state in('draft','cancelled')"
                        />
                        <button name="action_new_landed_cost"
                                string="New Landed Cost"
                                type="object"
                                class="btn-primary"
                                invisible="state in('draft','cancelled')"/>
                        <button
                                name="action_create_vendor_bill"
                                type="object"
                                string="Create Vendor Bill"
                                class="btn-primary"
                                invisible="payment_type != 'upass'"/>


                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,received,cancelled"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!-- Smart button for Stock Pickings -->
                            <button name="action_view_picking"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-truck"
                                    invisible="picking_count == 0">
                                <field name="picking_count" widget="statinfo" string="Receipts"/>
                            </button>
                            <button
                                    name="action_view_vendor_bill"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o"
                                    string="Shipment Vendor Bills">
                                <field name="vendor_bill_count" string="Vendor Bills" widget="statinfo"/>
                            </button>
                            <button name="action_view_landed_costs"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-cubes">
                                <field string="Landed Costs" name="landed_cost_count" widget="statinfo"/>
                            </button>
                            <button name="action_view_custom_duty_journals"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o"
                                    invisible="custom_duty_journal_count == 0">
                                <field name="custom_duty_journal_count" widget="statinfo" string="Custom Duty Entry"/>
                            </button>
                            <button name="action_view_add_charge_vendor_bills"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-pencil-square-o">
                                <field name="add_charge_vendor_bill_count" widget="statinfo" string="Charge Vendor Bills"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="lc_id" readonly="1"/>
                                <field name="po_id" readonly="1" force_save="1"/>
                                <field name="shipment_date"/>
                                <field name="partner_id"/>
                            </group>
                            <group>
                                <field name="state" readonly="1"/>
                                <field name="company_id" options="{'no_open': True, 'no_create': True}" readonly="1"/>
                                <field name="currency_id" readonly="1" force_save="1"/>
                                <field name="company_currency_id"/>
                                <field name="local_currency"/>
                                <field name="purchase_process"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Products">
                                <field name="shipment_line_ids" mode="list,form">
                                    <list editable="bottom">
                                        <field name="lc_line_id" readonly="1"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="quantity"/>
                                        <field name="currency_id" readonly="1" force_save="1"/>
                                        <field name="product_uom"/>
                                        <field name="price_unit"/>
                                        <field name="foreign_currency" force_save="1"/>
                                        <field name="foreign_price_subtotal" force_save="1"/>
                                        <field name="price_subtotal" force_save="1"/>
                                        <field name="remaining_qty" readonly="1" force_save="1" invisible="1"/>
                                    </list>
                                    <form>
                                        <group>
                                            <field name="lc_line_id" readonly="1"/>
                                            <field name="product_id" readonly="1"/>
                                            <field name="quantity"/>
                                            <field name="currency_id" readonly="1" force_save="1"/>
                                            <field name="product_uom"/>
                                            <field name="price_unit"/>
                                            <field name="foreign_currency" force_save="1"/>
                                            <field name="foreign_price_subtotal" force_save="1"/>
                                            <field name="remaining_qty" readonly="1"/>
                                            <field name="price_subtotal" force_save="1"/>
                                            <field name="remaining_qty" readonly="1" force_save="1" invisible="1"/>
                                        </group>
                                    </form>
                                </field>
                                <group>
                                    <group>
                                        <field colspan="2" name="notes" nolabel="1"
                                               placeholder="Define your terms and conditions ..."/>
                                    </group>
                                    <group class="oe_subtotal_footer oe_right">
                                        <field name="amount_total" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Landed Costs">
                                <group>
                                    <field name="custom_duty_journals" readonly="1" force_save="1"
                                           widget="many2many_tags"/>
                                </group>
                                <group>
                                    <group>
                                        <field name="add_charge_vendor_bill" readonly="1"
                                               force_save="1" widget="many2many_tags"/>
                                    </group>
                                </group>
                                <field name="cost_line_ids" context="{'default_shipment_id': id}">
                                    <list editable="bottom">
                                        <field name="landed_cost_type"/>
                                        <field name="product_id"/>
                                        <field name="lc_product_id"/>
                                        <field name="amount"/>
                                        <field name="split_method"/>
                                        <field name="account_id"/>
                                        <field name="payment_amount"/>
                                        <field name="remaining_amount"/>
                                        <field name="is_payed"/>
                                    </list>
                                    <form>
                                        <group>
                                            <group>
                                                <field name="landed_cost_type"/>
                                                <field name="product_id"/>
                                                <field name="lc_product_id"/>
                                                <field name="amount"/>
                                                <field name="split_method"/>
                                            </group>
                                            <group>
                                                <field name="account_id"/>
                                                <field name="lc_journal_id"/>
                                                <field name="payment_amount"/>
                                                <field name="remaining_amount"/>
                                                <field name="is_payed"/>
                                            </group>
                                        </group>
                                    </form>
                                </field>
                            </page>

                            <page string="Shipment Payment Info">
                                <group>
                                    <group>
                                        <field name="ship_margin_amount"/>
                                        <field name="lc_advance_amount"/>
                                        <field name="ship_advance_acc"/>
                                        <field name="amount_total_bdt"/>
                                        <field name="ship_margin_acc"/>
                                    </group>

                                    <group>
                                        <field name="ship_margin_journal"/>
                                        <field name="ship_margin_payment" readonly="1" force_save="1"/>
                                        <field name="payment_date"/>
                                        <field name="payment_type"/>
                                        <field name="ship_payment_amount"/>
                                    </group>
                                </group>

                            </page>

                            <page string="Notes">
                                <field name="notes" nolabel="1"/>
                            </page>

<!--                            <page string="Activities">-->
<!--                                <field name="activity_ids" mode="kanban" nolabel="1">-->
<!--                                    <kanban class="o_activity_kanban">-->
<!--                                        <templates>-->
<!--                                            <t t-name="kanban-box">-->
<!--                                                <div class="o_activity_record">-->
<!--                                                    <div class="o_activity_title">-->
<!--                                                        <field name="activity_type_id" readonly="1"/>-->
<!--                                                    </div>-->
<!--                                                    <div class="o_activity_summary">-->
<!--                                                        <field name="summary" readonly="1"/>-->
<!--                                                    </div>-->
<!--                                                    <div class="o_activity_date_deadline">-->
<!--                                                        <field name="date_deadline" readonly="1"/>-->
<!--                                                    </div>-->
<!--                                                </div>-->
<!--                                            </t>-->
<!--                                        </templates>-->
<!--                                    </kanban>-->
<!--                                </field>-->
<!--                            </page>-->
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View for LC Shipment -->
        <record id="view_lc_shipment_tree" model="ir.ui.view">
            <field name="name">lc.shipment.tree</field>
            <field name="model">lc.shipment</field>
            <field name="arch" type="xml">
                <list string="LC Shipments">
                    <field name="name"/>
                    <field name="lc_id"/>
                    <field name="shipment_date"/>
                    <field name="state"/>
                    <field name="company_id" invisible="1"/>
                </list>
            </field>
        </record>

