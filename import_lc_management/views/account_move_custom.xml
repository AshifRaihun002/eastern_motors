<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the form view of account.move to add custom fields -->
    <record id="view_move_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='ref']" position="after">

                <field name="custom_conversion_rate" readonly="1" string="Conversion Rate:" force_save="1" invisible="(currency_id == company_currency_id) or move_type != 'in_invoice'"/>
            </xpath>


        </field>
    </record>


</odoo>