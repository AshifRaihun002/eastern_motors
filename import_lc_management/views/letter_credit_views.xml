    <record id="lc_view_graph" model="ir.ui.view">
        <field name="name">letter.credit.graph</field>
        <field name="model">letter.credit</field>
        <field name="arch" type="xml">
            <graph string="Letter Of Credit">
                <field name="create_date" interval="day" type="measure"/>
                <field name="user_id" type="row"/>
            </graph>
        </field>
    </record>

    <record id="lc_view_pivot" model="ir.ui.view">
        <field name="name">letter.credit.pivot</field>
        <field name="model">letter.credit</field>
        <field name="arch" type="xml">
            <pivot string="Letter Of Credit">
                <field name="create_date" interval="day" type="row"/>
                <field name="user_id" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="lc_action_window" model="ir.actions.act_window">
        <field name="name">Letter Of Credit</field>
        <field name="res_model">letter.credit</field>
        <field name="type">ir.actions.act_window</field>
<!--        <field name="search_view_id" ref="lc_order_view_form_filter"/>-->
        <field name="view_mode">list,graph,pivot,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Letter Of Credit found. Let's create one!
            </p>
        </field>
    </record>


    <menuitem
            id="lc_menu"
            name="Letter of Credit"
            parent="import_lc_management.menu_root"
            action="lc_action_window"
            sequence="10"
            groups="import_lc_management.group_lc_ass_manager,import_lc_management.group_lc_senior_manager,group_lc_head_scm,group_lc_head_dept,import_lc_management.group_pasha_lc_manager"/>


</odoo>