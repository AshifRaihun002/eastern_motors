<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for LC Name -->
        <record id="lc_name_seq" model="ir.sequence">
            <field name="name">LC Name Sequence</field>
            <field name="code">lc_name</field>
            <field name="prefix">LC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Landed Cost Template Name -->
        <record id="landed_cost_template_name_seq" model="ir.sequence">
            <field name="name">Landed Cost Name Sequence</field>
            <field name="code">landed_cost_template_name</field>
            <field name="prefix">LCT</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_lc_shipment" model="ir.sequence">
            <field name="name">LC Shipment</field>
            <field name="code">lc.shipment</field>
            <field name="prefix">SHIP</field>
            <field name="padding">3</field>
            <field name="implementation">no_gap</field>
        </record>

    </data>
</odoo>

