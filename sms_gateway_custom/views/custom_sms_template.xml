<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!--Search View-->
    <record id="sms_template_view_search" model="ir.ui.view">
        <field name="name">sms.template.custom.search</field>
        <field name="model">sms.template.custom</field>
        <field name="arch" type="xml">
            <search string="Search Cheque Book Bank">
                <field name="type"/>
                <field name="format_no"/>
                <field name="sms_format"/>
                <filter string="Active Format" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactive Format" name="active" domain="[('is_active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!--List View-->
    <record id="sms_template_view_list" model="ir.ui.view">
        <field name="name">sms.template.custom.list</field>
        <field name="model">sms.template.custom</field>
        <field name="arch" type="xml">
            <list delete="false" string="SMS Template List">
                <field name="type"/>
                <field name="format_no"/>
                <field name="is_header_sent"/>
                <field name="header_text"/>
                <field name="sms_format"/>
                <field name="is_footer_sent"/>
                <field name="footer_text"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!--Form View-->
    <record id="sms_template_view_form" model="ir.ui.view">
        <field name="name">sms.template.custom.form</field>
        <field name="model">sms.template.custom</field>
        <field name="arch" type="xml">
            <form  delete="false" string="SMS Template Form">
                <sheet>
                    <group>
                        <group>
                            <field name="type" required="1"/>
                            <field name="format_no" required="1"/>
                            <field name="is_header_sent" />
							<field name="header_text" />
							<field name="sms_format" required="1"/>
							<field name="is_footer_sent" />
							<field name="footer_text" />
                            <field name="is_active" required="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--Main Action-->
    <record id="action_sms_template" model="ir.actions.act_window">
        <field name="name">SMS Template</field>
        <field name="res_model">sms.template.custom</field>
        <field name="context">{}</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Please Create SMS Format
            </p>
        </field>
    </record>
</odoo>