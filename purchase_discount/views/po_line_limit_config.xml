<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_direct_purchase" model="ir.ui.view">
        <field name="name">Res Config Settings - Direct Purchase Limits</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Direct Purchase Settings" name="direct_purchase_settings">
                    <block title="Direct Purchase Limits" name="direct_purchase_limits">
                        <group>
                            <field name="is_direct_purchase_line_limit_active" options="{'no_create': True}"/>
                            <field name="direct_purchase_line_limit" options="{'no_create': True}"/>
                        </group>
                    </block>
                </app>
                <app string="Purchase Received Settings" name="purchase_received_settings">
                    <block title="Purchase Over Receive Limits" name="purchase_over_receive_limits">
                        <group>
                            <field name="is_purchase_over_receipt_active" options="{'no_create': True}"/>
                            <field name="purchase_over_receipt_percentage" options="{'no_create': True}"/>
                        </group>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
