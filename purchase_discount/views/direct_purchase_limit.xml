<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Configuration Form View -->
    <record id="view_direct_purchase_config_form" model="ir.ui.view">
        <field name="name">direct.purchase.config.form</field>
        <field name="model">direct.purchase.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Direct Purchase Settings">
                            <field name="is_active"/>
                            <field name="direct_purchase_limit"/>
                            <field name="direct_purchase_line_limit"/>
                            <field name="concern_dept"/>
                        </group>
                        <group string="Company">
                            <field name="company_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Configuration Tree View -->
    <record id="view_direct_purchase_config_tree" model="ir.ui.view">
        <field name="name">direct.purchase.config.tree</field>
        <field name="model">direct.purchase.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="company_id"/>
                <field name="is_active"/>
                <field name="concern_dept"/>
                <field name="direct_purchase_limit"/>
            </list>
        </field>
    </record>

    <!-- Action for Configuration -->
    <record id="action_direct_purchase_config" model="ir.actions.act_window">
        <field name="name">Direct Purchase Configuration</field>
        <field name="res_model">direct.purchase.config</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_current_company': 1}</field>
    </record>

    <!-- Menu Item in Purchase Configuration -->
    <menuitem
        id="menu_direct_purchase_config"
        name="Direct Purchase Limit"
        parent="purchase.menu_purchase_config"
        action="action_direct_purchase_config"
        sequence="10"/>
</odoo>